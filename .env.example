# PubMed API Key (Optional but recommended for higher rate limits)
NCBI_API_KEY=your_ncbi_api_key_here

# Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# WordPress Credentials
WP_USER=your_wordpress_username
WP_APP_PASS=your_wordpress_application_password

# Email Settings (Optional, used if delivery mode is "email")
# For Gmail, use an "App Password" (not your main password)
SMTP_PASS=your_email_app_password_here
